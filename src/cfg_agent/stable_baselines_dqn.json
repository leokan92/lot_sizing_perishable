        "dqn_action_seed": 12345,
        "n_envs": 6,
        "vec_env_type": "dummy",
        "device": "auto",
        "verbose": 0,
        "logger_settings": {
            "log_step_details": true,
            "log_dir": "./src/results/simulation_logs/",
            "log_actions": true
        },
        "sb3_params": {
            "learning_rate": 0.001,
            "buffer_size": 50000,
            "batch_size": 32,
            "exploration_fraction": 0.77,
            "exploration_final_eps": 0.01,
            "gamma": 0.99,
            "target_update_interval": 20,
            "train_freq": 1,
            "gradient_steps": 1
        }
    }
