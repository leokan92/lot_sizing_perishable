{
    "agent_type": "stable_baselines",
    "params": {
        "algorithm": "DQN",
        "policy": "MlpPolicy",
        "total_timesteps": 2000000,
        "num_final_eval_episodes": 50,
        "deterministic_eval": true,
        "train_log_interval": 10,
        "max_order_quantity": 20,
